# ============================================
# OpenAI / 大模型配置
# 支持 OpenAI 官方 API 及兼容接口（DeepSeek、智谱、通义等）
# 如果直连不了 OpenAI，设置 OPENAI_PROXY
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=local
OPENAI_TIMEOUT=30
OPENAI_PROXY=

# ============================================
# HuggingFace 配置（本地语义嵌入 + 重排序模型）
# ============================================
# 国内用户建议设置镜像站加速下载（留空则默认访问 huggingface.co）
HF_ENDPOINT=https://hf-mirror.com

# 本地语义嵌入模型（中文推荐 BAAI/bge-small-zh-v1.5）
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 重排序模型（提升检索精度，首次运行自动下载 ~1GB）
RERANKER_MODEL=BAAI/bge-reranker-base

# 对话记忆有效期（秒），超时自动清除
CONVERSATION_TTL_SECONDS=3600

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=smart_doc_qa

# ============================================
# Redis 配置（可选，用于缓存和任务队列）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# 应用配置
# ============================================
APP_NAME=SmartDocQA
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 向量存储路径（默认为项目根目录下的 data/vector_store）
# 每个文档会在此路径下创建以文档 ID 命名的子目录，存储 FAISS 索引和分块缓存
VECTOR_STORE_PATH=

# 支持的文件类型（逗号分隔，需带点号前缀）
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx,.csv

# 文件大小限制 (MB)，超过此限制拒绝上传
MAX_FILE_SIZE_MB=10

# 文本分块参数 — CHUNK_SIZE 越大单个块内容越多，CHUNK_OVERLAP 越大块间重叠越多
# 建议中文文档 800~1200，英文文档 1000~1500
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── 以下为高级配置，一般无需修改 ──

# OpenAI 请求超时时间 (秒)
OPENAI_TIMEOUT=60

# HTTP 代理地址（如 http://127.0.0.1:7890），留空则不使用代理
OPENAI_PROXY=
