# ============================================
# OpenAI / 大模型配置
# 支持 OpenAI 官方 API 及兼容接口（智谱、千帆、通义等）
# 如果直连不了 OpenAI，设置 OPENAI_PROXY
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=30
OPENAI_PROXY=

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=smart_doc_qa

# ============================================
# Redis 配置（可选，用于缓存和任务队列）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# 应用配置
# ============================================
APP_NAME=SmartDocQA
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 向量存储路径
VECTOR_STORE_PATH=./data/vector_store

# 支持的文件类型
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx,.csv

# 文件大小限制 (MB)
MAX_FILE_SIZE_MB=10

# 文本分块大小
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
